# ===========================================
# Future Stars School Website - Backend Config
# ===========================================
# Copy this file to .env and update the values

# Server Configuration
PORT=5000
NODE_ENV=development

# Allowed frontend origins (comma-separated)
# Example: https://futurestars.netlify.app,https://www.yourdomain.com
# Leave empty to allow all origins (not recommended in production)
CORS_ORIGIN=

# MongoDB Configuration
# Local: mongodb://localhost:27017/school_website
# Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/school_website
MONGO_URI=mongodb://localhost:27017/school_website

# ===========================================
# SETUP INSTRUCTIONS:
# ===========================================
# 1. Install MongoDB or create a free MongoDB Atlas cluster
# 2. Copy this file: cp .env.example .env
# 3. Update MONGO_URI with your MongoDB connection string
# 4. Run: npm install
# 5. Run: npm start (collections will be auto-created & seeded)
# ===========================================

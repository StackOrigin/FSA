# ===========================================
# Future Stars School Website - Backend Config
# ===========================================
# Copy this file to .env and update the values

# Server Configuration
PORT=5000
NODE_ENV=development

# Allowed frontend origins (comma-separated)
# Example: https://futurestars.netlify.app,https://www.yourdomain.com
# Leave empty to allow all origins (not recommended in production)
CORS_ORIGIN=

# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=school_website
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# ===========================================
# SETUP INSTRUCTIONS:
# ===========================================
# 1. Install PostgreSQL if not already installed
# 2. Create the database (run in psql or pgAdmin):
#    CREATE DATABASE school_website;
# 3. Copy this file: cp .env.example .env
# 4. Update DB_PASSWORD with your PostgreSQL password
# 5. Run: npm install
# 6. Run: npm start (tables will be auto-created)
# ===========================================
